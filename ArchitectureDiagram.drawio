                <mxCell id="HpeB49ZlNlcB6vtWvLAx-52" value="" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#0000FF;" parent="1" target="HpeB49ZlNlcB6vtWvLAx-44" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="125" y="326.5" as="sourcePoint"/>
                        <mxPoint x="199" y="322.5" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="HpeB49ZlNlcB6vtWvLAx-53" value="" style="endArrow=classic;html=1;rounded=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;strokeColor=#0000FF;" parent="1" source="HpeB49ZlNlcB6vtWvLAx-48" target="HpeB49ZlNlcB6vtWvLAx-43" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="155" y="446.5" as="sourcePoint"/>
                        <mxPoint x="199" y="352.5" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="HpeB49ZlNlcB6vtWvLAx-54" value="" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=1;entryDx=0;entryDy=0;" parent="1" target="HpeB49ZlNlcB6vtWvLAx-47" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="115" y="432.5" as="sourcePoint"/>
                        <mxPoint x="159" y="338.5" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="HpeB49ZlNlcB6vtWvLAx-47" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeColor=#CC0066;" parent="1" vertex="1">
                    <mxGeometry x="95" y="422.5" width="30" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="HpeB49ZlNlcB6vtWvLAx-56" value="Create 1 graph per window" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Segoe UI;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="278.5" width="190" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="HpeB49ZlNlcB6vtWvLAx-57" value="&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;b&gt;&lt;font style=&quot;color: rgb(204, 0, 102);&quot;&gt;Node = (IP address)&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(204, 0, 102);&quot;&gt;Its 32-dim&#39;fingerprint&#39; is built from the IP + its neighbours&lt;/font&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Segoe UI;fontSize=12;spacing=4;fontColor=#CC0066;" parent="1" vertex="1">
                    <mxGeometry x="215" y="350" width="185" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="HpeB49ZlNlcB6vtWvLAx-58" value="&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 255);&quot;&gt;&lt;b&gt;Edge = one flow&lt;/b&gt; (a connection between two IPs)&lt;/font&gt;&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontFamily=Segoe UI;fontSize=12;spacing=4;fontColor=#0000FF;" parent="1" vertex="1">
                    <mxGeometry x="40" y="452.5" width="225" height="37.5" as="geometry"/>
                </mxCell>
                <mxCell id="HpeB49ZlNlcB6vtWvLAx-60" value="Training data: almost entirely &lt;b&gt;normal / benign&lt;/b&gt; traffic&lt;div&gt;(the model only ever learns what NORMAL looks like)&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Segoe UI;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="30" y="90" width="350" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-1" value="" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="200" y="310" as="sourcePoint"/>
                        <mxPoint x="430" y="310" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-2" value="③ Encoder — compress the graph" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontFamily=Segoe UI;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="440" y="210" width="250" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="578rkK1eknUj8itF5g7i-3" target="578rkK1eknUj8itF5g7i-4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-3" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;1. Graph Attention Network (GAT)&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;i&gt;4 &#39;heads&#39;&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Each computer updates its fingerprint by &#39;listening&#39; to its neighbours&#39; flows— paying &lt;b&gt;more attention&lt;/b&gt; to the important ones (the model learns which).&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=top;spacing=10;fontFamily=Segoe UI;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="440" y="249" width="320" height="111" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="578rkK1eknUj8itF5g7i-4" target="578rkK1eknUj8itF5g7i-6" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-4" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;2. Activation (ELU) → BatchNorm&lt;/b&gt;&lt;/span&gt;&lt;div&gt;Normalise fingerprint so training stays stable.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=top;spacing=10;fontFamily=Segoe UI;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="440" y="380" width="320" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="578rkK1eknUj8itF5g7i-6" target="578rkK1eknUj8itF5g7i-8" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-6" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;3. Graph U-Net&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;i&gt;3 levels&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Zooms OUT to a summary of the whole graph, then back IN — so each fingerprint captures both close-up detail and the big picture.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=top;spacing=10;fontFamily=Segoe UI;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="440" y="454" width="320" height="116" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-8" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Output: z&lt;/b&gt;&lt;/span&gt;&lt;div&gt;one finished fingerprint (embedding) per computer&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;spacing=10;fontFamily=Segoe UI;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="440" y="590" width="320" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-10" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;④ Global context&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Average all the flows together, pass through a small neural net (MLP) → one 128-dim summary &lt;b&gt;g.&lt;/b&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;verticalAlign=top;spacing=10;fontFamily=Segoe UI;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="37.5" y="687" width="242.5" height="96" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-12" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;⑤ Decoder — rebuilds each flow&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;For a flow A→B, use only the two fingerprints z[A], z[B], g to &lt;b&gt;guess&lt;/b&gt; what flow looked like.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;verticalAlign=top;spacing=10;fontFamily=Segoe UI;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="440" y="690" width="320" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-17" value="" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;exitX=0.533;exitY=0.975;exitDx=0;exitDy=0;exitPerimeter=0;" parent="1" source="HpeB49ZlNlcB6vtWvLAx-58" target="578rkK1eknUj8itF5g7i-10" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="140" y="510" as="sourcePoint"/>
                        <mxPoint x="140" y="668" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-18" value="g" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;fontFamily=Segoe UI;fontSize=13;fontStyle=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" parent="1" source="578rkK1eknUj8itF5g7i-10" target="578rkK1eknUj8itF5g7i-12" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="280" y="810" as="sourcePoint"/>
                        <mxPoint x="343" y="850" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-19" value="z" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;width=14.285714285714285;endSize=7.20952380952381;endWidth=26;fontFamily=Segoe UI;fontSize=13;fontStyle=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" parent="1" source="578rkK1eknUj8itF5g7i-8" target="578rkK1eknUj8itF5g7i-12" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="575" y="749" as="sourcePoint"/>
                        <mxPoint x="575" y="814" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-20" value="" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="599.47" y="780" as="sourcePoint"/>
                        <mxPoint x="599.47" y="820" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-21" value="Compare the GUESS vs the REAL flow" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Segoe UI;fontSize=13;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="475" y="820" width="250" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="578rkK1eknUj8itF5g7i-23" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;⑥ Reconstruction error&lt;/b&gt;&lt;/span&gt;&lt;div&gt;how far the guess was off (MSE per flow)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;•&amp;nbsp;Low error → &lt;b&gt;normal;&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;High error → &lt;/span&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;anomaly&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Cut-off is chosen automatically from the ROC curve (Youden&#39;s J).&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=top;spacing=10;fontFamily=Segoe UI;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="440" y="850" width="320" height="110" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
